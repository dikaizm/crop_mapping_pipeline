# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# RunPod API key — required for --shutdown flag
# Get from: RunPod → Settings → API Keys
RUNPOD_API_KEY=your-runpod-api-key-here

# RUNPOD_POD_ID is set automatically by RunPod — no need to set it here

# V5 local path overrides (optional — skips CLI args for process_data_v5.py)
RAW_S2_V5_DIR=/path/to/raw_v5
PROCESSED_V5_DIR=/path/to/processed_v5
